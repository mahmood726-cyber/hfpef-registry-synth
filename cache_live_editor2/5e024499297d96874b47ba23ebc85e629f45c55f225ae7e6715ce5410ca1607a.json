    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "Cardiac function and functional status and biochemical parameters",
          "description": "Cardiac function (echocardiography): Systolic function (left ventricular ejection fraction) and diastolic function (Doppler E/A ratio, tissue Doppler e/e1 ratio, Doppler deceleration time of the E wave, left atrium volume index) Maximal oxygen consumption will be evaluated with cardiopulmonary exercise testing Changes in proBNP level (serum value) after treatment",
          "timeFrame": "After 6 months"
        }
      ],
      "secondaryOutcomes": [
        {
          "measure": "Cardiovascular mortality",
          "description": "Death from cardiovascular reasons",
          "timeFrame": "Up to 6 months"
        },
