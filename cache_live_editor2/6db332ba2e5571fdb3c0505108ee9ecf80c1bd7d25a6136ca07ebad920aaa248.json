    "descriptionModule": {
      "briefSummary": "This is a limited safety and feasibility study to evaluate the PVSS Introducer and Paracor Ventricular Support System when used to treat patients with heart failure. The implant, which is loaded onto the delivery system, is placed over the epicardial surface of the right and left ventricles.\n\nNo formal hypothesis testing will be performed; descriptive statistics will be used to summarize patient outcomes. The results of the study will be used to guide the design and sample size estimation of future studies.",
      "detailedDescription": "Please refer to brief summary."
    },
    "conditionsModule": {
      "conditions": [
        "Heart Failure, Congestive"
      ]
    },
