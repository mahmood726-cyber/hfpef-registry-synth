    "descriptionModule": {
      "briefSummary": "This study was designed to determine whether COREG MR is more effective than TOPROL-XL in reducing microalbuminuria in type 2 diabetic or non-diabetic patients with high blood pressure and microalbuminuria."
    },
    "conditionsModule": {
      "conditions": [
        "Heart Failure, Congestive and Microalbuminuria"
      ],
      "keywords": [
        "hypertension",
        "urine albumin:creatinine ratio",
        "microalbuminuria"
      ]
    },
