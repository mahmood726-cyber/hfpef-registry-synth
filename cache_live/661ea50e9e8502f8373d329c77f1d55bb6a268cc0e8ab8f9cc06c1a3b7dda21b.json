    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "In cardiac MRI- infarct size (total late enhancement volume at day 3-7)",
          "description": "MRI: magnetic resonance image",
          "timeFrame": "day 3~7 after percutaneous coronary intervention"
        }
      ],
      "secondaryOutcomes": [
        {
          "measure": "in-hospital and after 1-months:the major adverse cardiovascular events : death, myocardial infarction, hospitalization for heart failure, myocardial ischemia, etc.",
          "timeFrame": "1 month"
        },
        {
          "measure": "b. major bleeding : Hemoglobin 4 or more reduction, 2-unit If you need more than two RBC transfusions, intracranial or retroperitoneal bleeding, urgent operation for bleeding complication.",
          "description": "RBC: red blood cell",
          "timeFrame": "1 month"
        },
        {
          "measure": "TIMI III flow count /myocardial blush score after PCI",
          "description": "TIMI: thrombolysis in myocardial infarction PCI: percutaneous coronary intervention",
          "timeFrame": "1 day"
        },
        {
          "measure": "At cardiac MRI : LV ejection fraction,LV end-systolic volume,LV end diastolic volume,regional wall motion score index",
          "description": "LV: left ventricle",
          "timeFrame": "1 week"
        },
        {
          "measure": "Discharge, 1- month after comparing NT-proBNP",
          "description": "NT-proBNP : N-terminal pro-B-Type natriuretic peptide",
          "timeFrame": "1 month"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n* non-ST segment elevation acute myocardial infarction\n* within 48 hours presence of chest pain\n* Troponin-T or I positive before CAG\n* First myocardial infarction\n* will be performed coronary angioplasty\n\nExclusion Criteria:\n\n* under 18 years of age,80 years or older\n* Bleeding tendency\n* History of major surgery within 4 weeks\n* Major stroke within 2 years\n* Thrombocytopenia (\\<120,000 / uL)\n* Cardiogenic shock\n* Known allergy to aspirin, heparin, or abciximab\n* Contraindication of MRI at study entry (implanted pacemakers, defibrillators, intracranial metallic implants etc)\n* Chronic atrial fibrillation\n* Pregnancy",
      "healthyVolunteers": false,
