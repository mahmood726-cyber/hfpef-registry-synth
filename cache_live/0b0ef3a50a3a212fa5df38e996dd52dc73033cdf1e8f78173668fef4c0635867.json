    "outcomeMeasuresModule": {
      "outcomeMeasures": [
        {
          "type": "PRIMARY",
          "title": "Peak Volume of Oxygen Uptake (Peak VO2) - Rate Adaptive Pacing (RAP) On at One Month vs. Rate Adaptive Pacing (RAP) Off at One Month.",
          "description": "Randomized therapy order cross-over comparison at 1 month post-implant. Each patient evaluated for endpoint with and without RAP therapy at this time.",
          "populationDescription": "The following were required for a patient's dataset to be included in the analysis:\n\n1. 2 CPX tests had to be performed at 1M (RAP On \\& RAP Off),\n2. Each 1M CPX test had to result in RER ≥ 1.05,\n3. Trending data from the disk had to have been obtained during each 1M CPX test.",
          "reportingStatus": "POSTED",
          "paramType": "MEAN",
          "dispersionType": "Standard Deviation",
          "unitOfMeasure": "ml/kg/min",
          "timeFrame": "1 month post implant",
          "groups": [
