    "outcomeMeasuresModule": {
      "outcomeMeasures": [
        {
          "type": "PRIMARY",
          "title": "Waveform and Components of Accelerometer Signal",
          "description": "Accelerometer signal was measured using the 3 axis Micra accelerometer (Vector 1 was labelled as V1, Vector 2 as V2, Vector 3 as V3).\n\nComponents of the accelerometer signals (unit (g) represent acceleration)were identified and labelled as A1 (acceleration associated with ventricular systole), A2 (ventricular diastole), A3 (early passive filling), and A4 (active filling). The A4 signal is associated with atrial contraction and active filling.",
          "populationDescription": "Of the 43 subjects enrolled, 12 with Atrial tachycardia / Atrial fibrillation and 2nd degree or greater atrioventricular block were excluded from analysis since the A4 signal is absent or variable. An additional 4 subjects in sinus rhythm were excluded from analysis due to frequent pacing or telemetry noise, resulting in 27 subjects for analysis.",
          "reportingStatus": "POSTED",
          "paramType": "MEAN",
          "dispersionType": "Standard Deviation",
          "unitOfMeasure": "g (unit (g) represent acceleration)",
          "timeFrame": "For approximately two hours after software download",
