    "armsInterventionsModule": {
      "armGroups": [
        {
          "label": "Rheos ON",
          "type": "OTHER",
          "description": "Study participants in this arm will have the device turn on for six months and remains on.",
          "interventionNames": [
            "Device: Rheos Baroreflex Activation Therapy System"
          ]
        },
