    "descriptionModule": {
      "briefSummary": "The CVRx® Rheos® Diastolic Heart Failure Trial is a prospective, randomized, double blind trial with up to 60 subjects conducted at up to five centers in Europe. All subjects will be followed up to one year post implant."
    },
