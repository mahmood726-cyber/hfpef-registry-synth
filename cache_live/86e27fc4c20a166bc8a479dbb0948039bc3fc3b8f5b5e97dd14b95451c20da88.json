    "armsInterventionsModule": {
      "armGroups": [
        {
          "label": "Candemore tablet",
          "type": "EXPERIMENTAL",
          "description": "Candemore tablet\n\n* Initial dose : 4mg/day if SBP\\<140mmHg and/or DBP\\<90mmHg, 8mg/day if SBP≥140mmHg and DBP≥90mmHg\n* dose escalation : double dose if SBP≥100mmHg and DBP\\>60mmHg (maximum dose 16mg/day)",
          "interventionNames": [
            "Drug: Candemore tablet"
          ]
        },
        {
          "label": "Atacand tablet",
          "type": "ACTIVE_COMPARATOR",
          "description": "Atacand tablet\n\n* Initial dose : 4mg/day if SBP\\<140mmHg and/or DBP\\<90mmHg, 8mg/day if SBP≥140mmHg and DBP≥90mmHg\n* dose escalation : double dose if SBP≥100mmHg and DBP\\>60mmHg (maximum dose 16mg/day)",
          "interventionNames": [
            "Drug: Atacand tablet"
          ]
        }
      ],
      "interventions": [
        {
