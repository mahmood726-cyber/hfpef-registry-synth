      "interventions": [
        {
          "type": "DRUG",
          "name": "Somatotropin",
          "description": "Subcutaneous Somatotropin (recombinant Human Growth Hormone) 0,012 mg/kg every second day",
          "armGroupLabels": [
            "GH replacement"
          ]
        }
      ]
