    "descriptionModule": {
      "briefSummary": "A trial of patients with type 2 diabetes mellitus to evaluate the comparative effectiveness between dapagliflozin and Standard of Care (SOC)",
      "detailedDescription": "A longitudinal, open labelled, pragmatic randomized 104 week multicentre trial of patients with type 2 diabetes mellitus to evaluate the comparative effectiveness between dapagliflozin and Standard of Care (SOC)"
    },
