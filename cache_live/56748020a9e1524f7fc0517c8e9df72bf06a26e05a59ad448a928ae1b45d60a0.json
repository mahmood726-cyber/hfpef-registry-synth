    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "Changes in Sympathetic Nervous System Activity (MSNA Bursts/Min)",
          "description": "Change in muscle sympathetic nerve activity (MSNA) in bursts/min at 6 months compared to baseline",
          "timeFrame": "6 months"
        },
        {
          "measure": "Changes in Sympathetic Nervous System Activity (MSNA Bursts/100 Heartbeats)",
          "description": "Changes in Muscle Sympathetic Nerve Activity (bursts/100 heartbeats) at 6 months compared to baseline",
          "timeFrame": "6 months"
        }
      ],
      "secondaryOutcomes": [
        {
          "measure": "Change in Systolic Blood Pressure",
          "description": "Change in systolic blood pressure at 6 months compared to baseline",
          "timeFrame": "6 months"
        },
        {
          "measure": "Change in Diastolic Blood Pressure",
          "description": "Change in diastolic blood pressure at 6 months compared to baseline",
          "timeFrame": "6 months"
        },
        {
          "measure": "Change in Heart Rate",
          "description": "Change in heart rate at 6 months compared to baseline",
          "timeFrame": "6 months"
        },
        {
          "measure": "Change in Six-Minute Hall Walk",
          "description": "Change in six-minute hall walk distance at 6 months compared to baseline. The 6-Minute Hall Walk test is a measure of physical function by measuring the distance a patient can walk in a 6-minute time period.",
          "timeFrame": "6 months"
        },
        {
          "measure": "New York Heart Association (NYHA) Class",
          "description": "Number of patients with NYHA Class I-IV at 6 months. NYHA classification places patients in one of four categories based on how much they are limited during physical activity, where Class I indicates no limitation of physical activity and Class IV indicates the patient is unable to carry on any physical activity without discomfort. The patient has symptoms of heart failure at rest, and if any physical activity is undertaken, discomfort increases.",
          "timeFrame": "Six months"
        },
        {
          "measure": "Change in Quality of Life (Minnesota Living With Heart Failure Questionnaire)",
          "description": "Change in Quality of Life as measured by the Minnesota Living with Heart Failure Questionnaire at 6 months compared to baseline.\n\nThe Minnesota Living with Heart Failure Questionnaire is a 21-item questionnaire designed as a measure of heart failure, as indicated by its adverse effects on patients' lives. Each item is scored in a 6-point Likert Scale (0 to 5); therefore, the total score could range from 0 to 105, with higher scores indicating more significant impairment in health-related quality of life.",
          "timeFrame": "Six months"
        },
        {
          "measure": "Change in Left Ventricular Ejection Fraction (LVEF)",
          "description": "Change in LVEF at 6 months compared to baseline",
          "timeFrame": "Six months"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n* Age at least 21 years\n* Symptomatic heart failure despite optimal, stable pharmacological therapy for at least 4 weeks\n\nExclusion Criteria:\n\n* Significant carotid plaque or stenosis\n* Known or suspected baroreflex failure or autonomic neuropathy\n* Myocardial infarction, unstable angina, syncope, cerebral vascular accident, SCD, or received defibrillation therapy within the past 3 months\n* Heart failure secondary to a reversible condition",
      "healthyVolunteers": false,
      "sex": "ALL",
      "minimumAge": "21 Years",
      "stdAges": [
        "ADULT",
        "OLDER_ADULT"
      ]
    },
