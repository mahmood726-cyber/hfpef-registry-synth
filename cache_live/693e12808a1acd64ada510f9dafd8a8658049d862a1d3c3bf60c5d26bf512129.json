    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "Change from baseline to end-of-therapy in Left Ventricular Ejection Fraction, as measured using CMR imaging",
          "timeFrame": "6 months"
        }
      ],
      "secondaryOutcomes": [
        {
          "measure": "Change in LV systolic and diastolic volume (and/or diameter) by CMR",
          "timeFrame": "6 months"
        },
        {
          "measure": "Change in NYHA functional class",
          "timeFrame": "6 months"
        },
        {
          "measure": "Change in various biomarkers for heart failure",
          "timeFrame": "6 months"
        },
        {
          "measure": "Change in QoL-scores",
          "timeFrame": "6 months"
        },
        {
          "measure": "Change in 6-minute walk distance",
          "timeFrame": "6 months"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n* Clinical diagnosis of CHF (NYHA class II-IV)\n* Locally determined LVEF \\< 0.35 (by CMR, echocardiography, LV angiography, or radionuclide cardioangiography)\n* Stable sinus rhythm\n* Stable evidence based pharmacological treatment for CHF.\n\nExclusion Criteria:\n\n* Unstable patients hospitalised within last 2 weeks\n* Baseline prolongation of QTc interval\n* Atrial fibrillation at randomisation\n* MI or re-vascularisation last 3 months\n* Stroke last 3 months.",
