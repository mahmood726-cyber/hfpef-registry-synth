    "armsInterventionsModule": {
      "armGroups": [
        {
          "label": "DASH diet group",
          "type": "EXPERIMENTAL",
          "description": "Participants randomized to receive the DASH diet will be prescribed an isocaloric DASH diet using meals (lunch, dinner, snacks) prepared by a Clinical Research Metabolic Kitchen under the direction of a registered dietician. Participants will prepare their own breakfast from a menu. The subjects will be instructed to drink no more than three caffeinated beverages and no more than two alcoholic beverages per day.",
          "interventionNames": [
            "Other: DASH Diet"
          ]
        },
        {
          "label": "Attention Control Group",
          "type": "ACTIVE_COMPARATOR",
          "description": "Participants randomized to attention control will continue their usual diet, but they will be instructed to limit their sodium intake to 2300 mg/day. They will be requested and voluntarily agree to not make additional diet or exercise changes during the 12-week study.",
          "interventionNames": [
            "Other: Usual diet"
          ]
        }
      ],
      "interventions": [
        {
          "type": "OTHER",
          "name": "DASH Diet",
          "description": "12 Weeks of isocaloric DASH diet \\<2300 mg Na/day using meals (lunch, dinner, snacks) prepared by the Wake Forest Clinical Research Metabolic Kitchen under the direction of a registered dietician (RD). Participants will prepare their own breakfast from a menu.The subjects will be instructed to drink no more than three caffeinated beverages and no more than two alcoholic beverages per day.",
          "armGroupLabels": [
            "DASH diet group"
          ],
          "otherNames": [
            "Dietary Approaches to Stop Hypertension"
          ]
