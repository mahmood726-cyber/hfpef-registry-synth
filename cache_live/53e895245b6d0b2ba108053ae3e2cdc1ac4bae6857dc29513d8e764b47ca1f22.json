    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n1. Males and females with a diagnosis of SBS-IF secondary to surgical resection of the small intestine, with Colon-in-Continuity (CIC) or stoma, who were trial subjects of parent trials TA799-007 or TA799-013\n2. Able to give informed consent and agree to follow the details of participation as outlined in the protocol.\n\nExclusion Criteria:\n\n1. Subject not capable of understanding or not willing to adhere to the trial visit schedules and other protocol requirements.\n2. Any other reason judged not eligible by the Investigator.\n3. Pregnancy or lactation",
      "healthyVolunteers": false,
      "sex": "ALL",
      "minimumAge": "18 Years",
      "stdAges": [
        "ADULT",
        "OLDER_ADULT"
      ]
    },
