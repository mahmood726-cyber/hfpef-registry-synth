            "Drug: Apraglutide"
          ]
        }
      ],
      "interventions": [
        {
          "type": "DRUG",
          "name": "Apraglutide",
          "description": "Apraglutide is a synthetic peptide analogue of GLP-2 under development for treatment of SBS-IF, which acts as a full agonist at the GLP-2 receptor with in vitro potency and selectivity comparable with native GLP-2",
          "armGroupLabels": [
            "Apraglutide subcutaneous (SC) injections, once weekly"
          ]
        }
      ]
    },
