    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "The primary efficacy measure will be exercise tolerance as assessed utilizing the 6 Minute Walk Test",
          "timeFrame": "Assessed at baseline, week 12 and week 24"
        }
      ],
      "secondaryOutcomes": [
        {
          "measure": "QOL as assessed by the Kansas City Cardiomyopathy Questionnaire",
          "timeFrame": "baseline, week 12 and week 24"
        },
        {
          "measure": "To assess New York Heart Association Classification",
          "timeFrame": "Baseline, week 12 and week 24"
        },
        {
          "measure": "To evaluate cardiovascular death or hospitalization for heart failure",
          "timeFrame": "Will be assessed during the entire 24 wk trial"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n* diagnosis of diabetes or hypertension requiring therapy\n* EF \\>/= 45% via echo within 1 year and evidence of diastolic heart failure via echo measurement of E/E'\\>/= 12 determined by echo within 1 year\n* previous hospitalization for heart failure or previous BNP \\>100 pg/mL.\n\nExclusion Criteria:\n\n* Clinically significant valvular disease\n* history of stroke/TIA or reversible ischemic neurological defect w/i 6 mths\n* history of acute MI within 6 months\n* severe COPD\n* active or treated malignancies (except basal cell carcinoma)\n* significant systemic illnesses that would prohibit completion of the study or compliance",
      "healthyVolunteers": false,
      "sex": "ALL",
      "minimumAge": "50 Years",
      "stdAges": [
        "ADULT",
        "OLDER_ADULT"
      ]
    },
