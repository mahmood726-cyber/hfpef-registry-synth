    "descriptionModule": {
      "briefSummary": "The purpose of this study is to evaluate the efficacy and safety of conduction system pacing versus biventricular pacing in patients with chronic heart failure with reduced ejection fraction and left bundle branch block."
    },
    "conditionsModule": {
      "conditions": [
        "Heart Failure",
        "Left Bundle-Branch Block",
        "Cardiac Resynchronization",
        "Conduction System Pacing"
      ]
    },
