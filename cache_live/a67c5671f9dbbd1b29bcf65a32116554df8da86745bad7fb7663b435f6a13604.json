    "armsInterventionsModule": {
      "armGroups": [
        {
          "label": "Conduction system pacing",
          "type": "EXPERIMENTAL",
          "description": "Patients will be randomized 1:1 to either conduction system pacing or biventricular pacing.",
          "interventionNames": [
            "Device: Conduction system pacing"
          ]
        },
        {
          "label": "Biventricular pacing",
          "type": "ACTIVE_COMPARATOR",
          "description": "Patients will be randomized 1:1 to either conduction system pacing or biventricular pacing.",
          "interventionNames": [
