          "measure": "Change from baseline to EOT in N-terminal pro b-type natriuretic peptide (NT-pro-BNP) values",
          "timeFrame": "12 Weeks"
        },
        {
          "measure": "Change in Kansas City Cardiomyopathy Questionnaire (KCCQ) scores from baseline",
          "description": "General Scoring Guideline: 0 to 24: very poor to poor; 25 to 49: poor to fair; 50 to 74: fair to good; and 75 to 100: good to excellent",
          "timeFrame": "16 Weeks"
        },
        {
          "measure": "Number of subjects with treatment-emergent adverse events",
          "timeFrame": "Up to 16 Weeks"
        },
        {
          "measure": "Trough plasma concentrations of JTT-861",
          "timeFrame": "Weeks 4, 8 and 12"
        },
        {
