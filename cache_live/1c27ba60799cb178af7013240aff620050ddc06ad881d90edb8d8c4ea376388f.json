    "armsInterventionsModule": {
      "armGroups": [
        {
          "label": "Coenzyme Q10",
          "type": "EXPERIMENTAL",
          "description": "Known cases of idiopathic dilated cardiomyopathy who received supplementation of coenzyme Q10 as a part of their medical regimen.\n\nDosage administered: 2 milligram/kilogram/day in 2 or 3 divided doses, these being increased to the maximum dose of 10 milligram/kilogram/day according to tolerance or the appearance of sideeffects.",
          "interventionNames": [
            "Drug: Coenzyme Q10"
          ]
        },
        {
          "label": "Placebo",
          "type": "PLACEBO_COMPARATOR",
          "description": "known cases of idiopathic dilated cardiomyopathy who received placebo",
          "interventionNames": [
            "Drug: Placebo"
          ]
        }
      ],
      "interventions": [
        {
          "type": "DRUG",
          "name": "Coenzyme Q10",
          "description": "dose of 2 mg/kg/day in 2 or 3 divided doses and increased to the maximum dose of 10 mg/kg/day according to the patient's tolerance",
          "armGroupLabels": [
            "Coenzyme Q10"
          ],
          "otherNames": [
            "Ubiquinone"
          ]
        },
        {
          "type": "DRUG",
