    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "Change in New York Heart Association Heart Failure Class",
          "description": "Change in New York Heart Association Heart Failure Class between baseline and 3 months, 6 months, 12 months, 18 months and 24 months",
          "timeFrame": "24 months"
        },
        {
          "measure": "Change in NT-proBNP blood test levels",
          "description": "Change in Amino-terminal prohormone of brain natriuretic peptide (NT-proBNP) between baseline and 3 months, 6 months, 12 months, 18 months, and 24 months",
          "timeFrame": "24 months"
        },
        {
          "measure": "Change in QoL as measured by the Kansas City Cardiomyopathy Questionnaire (KCCQ) and the EQ-5D Questionnaire.",
          "description": "Change in QoL measures between baseline and 3 months, 6 months, 12 months, 18 months, and 24 months will be measured. The KCCQ is used to measure the effect of heart failure on quality of life with a lower score indicating a worsening quality of life. The EQ-5D Questionnaire is a general measure of overall health with a lower score indicating a better overall health perception.",
          "timeFrame": "24 months"
        },
        {
          "measure": "Change in 6MHW distance",
          "description": "Change in 6MHW distance between baseline and 3 months, 6 months, 12 months, 18 months and 24 months",
          "timeFrame": "24 months"
        },
        {
          "measure": "Change in cardiac function / structure",
          "description": "Change will be evaluated using echocardiogram measured left ventricular ejection fraction, LV end diastolic volume, left atrial volume index, and severity of mitral regurgitation.",
          "timeFrame": "24 months"
        },
        {
          "measure": "Adverse Events",
          "description": "Incidence and severity of adverse events and serious adverse events, including serious adverse cardiovascular and neurological events",
          "timeFrame": "24 months"
        },
        {
          "measure": "Cardiovascular Mortality",
          "description": "Rate of cardiovascular mortality throughout the follow-up period will be reported.",
          "timeFrame": "24 months"
        },
        {
          "measure": "Heart Failure Hospitalizations",
          "description": "Rate of heart failure hospitalizations throughout the follow-up period will be reported.",
          "timeFrame": "24 months"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n1. Age 18 years or above\n2. Currently NYHA Class II, III or ambulatory IV heart failure\n3. Left ventricular ejection fraction ≤ 40%\n4. NT-proBNP ≥ 400\n5. Prescribed optimally-tolerated, stable, Guideline Directed Medical Therapy (GDMT) per country specific guidelines for the treatment of heart failure for at least 4 weeks\n6. Six-minute hall walk (6MHW) distance of ≥ 150 m AND ≤ 400 m\n7. Deemed an acceptable candidate for the implant procedure by the investigator\n\nExclusion Criteria:\n\n1. Known or clinically suspected baroreflex failure or autonomic neuropathy\n2. Currently implanted with a barostimulator device\n3. Received cardiac resynchronization therapy (CRT) within six months of implantation\n4. Received a CardioMEMS device within three months of the screening visit\n5. History of any prior stroke with permanent neurologic defect or any prior intracranial bleed or other serious brain injury\n6. Body mass index \\> 45\n7. Serum estimated glomerular filtration rate (eGFR) \\< 30 mL/min/1.73 m2\n8. Presence of atherosclerotic plaque in the intended side for implantation as determined by carotid duplex\n9. Internal ICA lumen diameters \\<5.0 mm or \\>11.75 mm within the planned location of the implant placement, or evidence of landing zone restrictions, such as inadequate length, vessel tapering, and/or vessel curvature that would preclude safe placement of the implant",
      "healthyVolunteers": false,
      "sex": "ALL",
      "minimumAge": "18 Years",
      "stdAges": [
        "ADULT",
        "OLDER_ADULT"
      ]
    },
