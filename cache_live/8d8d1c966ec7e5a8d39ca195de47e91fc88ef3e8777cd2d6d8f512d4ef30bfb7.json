    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "Change from baseline in trough sitting systolic and diastolic blood pressure measured by sphygmomanometry",
          "timeFrame": "Baseline to Week 14"
        }
      ],
      "secondaryOutcomes": [
        {
          "measure": "Change from baseline in mean 24-hour systolic and diastolic ambulatory blood pressure",
          "timeFrame": "Baseline to Week 14"
        },
        {
          "measure": "Percentage of subjects to reach systolic blood pressure goal",
          "timeFrame": "Week 14"
        },
        {
          "measure": "Change from baseline in estimated glomerular filtration rate (eGFR)",
          "timeFrame": "Baseline to Week 14"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n* Subjects who are competent to provide written consent\n* Aged 35 to 80 years\n* Subjects with diabetes and/or chronic kidney disease must have a mean systolic blood pressure ≥130 mmHg\n* All other subjects must have a mean systolic blood pressure ≥140 mmHg\n* Receiving and adhering to full doses of appropriate guideline-recommended antihypertensive drugs from three different classes of antihypertensive agents, including a diuretic\n* Female subjects of non-childbearing potential (i.e., post-menopausal for at lest 2 years; surgically sterile)\n\nExclusion Criteria:\n\n* Average sitting systolic blood pressure ≥180 mmHg or diastolic blood pressure ≥110 mmHg\n* Serum ALT or AST \\>2 x the upper limit of the normal range (ULN)\n* Subjects who have experienced myocardial infarction, unstable angina pectoris, or a cerebrovascular accident (CVA) within 6 month; or sick sinus syndrome or second or third degree atrioventricular block, atrial fibrillation or recurrent atrial tachyarrhythmia, recurrent ventricular tachycardia, or symptomatic bradycardia\n* Implanted pacemakers or implanted cardioverter defibrillator (ICD)\n* Symptomatic congestive heart failure requiring treatment\n* Hemodynamically significant valvular heart disease\n* Type I diabetes mellitus\n* Hemodialysis or peritoneal dialysis; or history of renal transplant\n* Diagnosis or recurrence of malignancy within the past 3 years\n* Sleep apnea, unless a recent sleep study demonstrates arterial oxygen saturation greater than or equal to 90%\n* Subjects who perform alternating shift or night work\n* Subjects who have participated in a clinical study involving another investigational drug or device within 4 weeks prior to Screening",
      "healthyVolunteers": false,
      "sex": "ALL",
      "minimumAge": "35 Years",
      "maximumAge": "80 Years",
      "stdAges": [
        "ADULT",
        "OLDER_ADULT"
      ]
    },
