    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "Difference between eplerenone and placebo in change from baseline in LV end diastolic volume index (EDVi) determined by equilibrium-gated radionuclide ventriculography (RVG)"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n* Current symptoms consistent with mild to moderate heart failure (NYHA functional class II and III)\n* LVEF (left ventricular ejection fraction) of \\<35% by equilibrium-gated RVG at screening\n* Therapy with an angiotensin converting enzyme inhibitor (ACEI) or angiotensin receptor blocker (ARB) and beta-blocker (BB) (unless documented intolerance) for at least 3 months duration and at dose that has not been adjusted within the previous 4 weeks\n\nExclusion Criteria:\n\n* Current decompensated heart failure or heart failure hospitalization or severe heart failure (NYHA functional class IV) within 6 months of screening\n* Use of eplerenone or spironolactone within 30 days of randomization or for more than 7 days within the previous 6 months",
      "healthyVolunteers": false,
      "sex": "ALL",
      "minimumAge": "21 Years",
      "stdAges": [
        "ADULT",
        "OLDER_ADULT"
      ]
    },
