      "interventions": [
        {
          "type": "DIAGNOSTIC_TEST",
          "name": "Optical coherence tomography(-angiography) OCT(A)",
          "description": "OCTA is a non-invasive diagnostic tool capable of generating cross-sectional coupes of the retina and choroid. Novel algorithms allow to render a 3-dimensional model of the ocular microcirculation based merely on the motion contrast of the circulating blood.",
