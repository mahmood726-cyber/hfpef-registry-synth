      "secondaryOutcomes": [
        {
          "measure": "Main Phase: Change in composite Z-score based on the 3 outcome measures: LVEDVi; LVESVi; NT-proBNP",
          "description": "The composite Z-score is calculated as the mean of the participant's 3 Z-scores for the change in the 3 outcome measures: Left ventricular end-diastolic volume indexed to body surface area (LVEDVi); Left ventricular end-systolic volume indexed to body surface area (LVESVi); N-terminal pro B-type natriuretic peptide (NT-proBNP)",
          "timeFrame": "From baseline to week 24"
        },
        {
          "measure": "Main Phase: Number of adverse events",
